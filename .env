# ══════════════════════════════════════════════════════════════════
# OpenBMC AI-BDD Portal — Environment Variables
# 參考腳本:
#   ci_test_area/openbmc-build-scripts/run-qemu-robot-test.sh
#   ci_test_area/openbmc-build-scripts/scripts/boot-qemu.sh
# ══════════════════════════════════════════════════════════════════

# ── Portal Server ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=true

# ── UPSTREAM_WORKSPACE ────────────────────────────────────────────
# 對應 run-qemu-robot-test.sh: UPSTREAM_WORKSPACE
# boot-qemu.sh 會以此作為 BASE_DIR (cd "${BASE_DIR}")
UPSTREAM_WORKSPACE=/home/andyeh/workspace/openbmc/build/ast2700-default

# ── MACHINE ───────────────────────────────────────────────────────
# 對應 boot-qemu.sh: MACHINE → 決定 QEMU -machine 參數
# ast2700-default → 使用 ast2700a1-evb + qemu-system-aarch64
# romulus         → 使用 romulus-bmc + qemu-system-arm
MACHINE=ast2700-default

# ── QEMU Binary ───────────────────────────────────────────────────
# 對應 run-qemu-robot-test.sh: QEMU_BIN (relative to UPSTREAM_WORKSPACE)
# ast2700-default 使用 aarch64:
QEMU_BINARY=/home/andyeh/workspace/openbmc/build/ast2700-default/tmp/work/x86_64-linux/qemu-helper-native/1.0/recipe-sysroot-native/usr/bin/qemu-system-aarch64

# ── QEMU Image Location ───────────────────────────────────────────
# 對應 boot-qemu.sh: DEFAULT_IMAGE_LOC (relative to UPSTREAM_WORKSPACE)
# 腳本預設: ./tmp/deploy/images/  → 自動掃描 {MACHINE}/obmc-phosphor-image-{MACHINE}.static.mtd
QEMU_IMAGE_DIR=/home/andyeh/workspace/openbmc/build/ast2700-default/tmp/deploy/images/ast2700-default
QEMU_DEFAULT_MACHINE=ast2700a1-evb

# ── QEMU Timer ───────────────────────────────────────────────────
# 對應 run-qemu-robot-test.sh: QEMU_RUN_TIMER (docker container 存活時間, 秒)
QEMU_RUN_TIMER=3600
# 對應 run-qemu-robot-test.sh: QEMU_LOGIN_TIMER (等待 OPENBMC-READY, 秒)
QEMU_LOGIN_TIMER=180
# Portal 內部使用 (等待 QEMU boot 完成的逾時)
QEMU_BOOT_TIMEOUT=300

# ── Docker ────────────────────────────────────────────────────────
# 對應 run-qemu-robot-test.sh: DOCKER_IMG_NAME
DOCKER_IMG_NAME=openbmc/ast2700-robot-qemu:Andy
DOCKER_SOCKET=/var/run/docker.sock
# 對應 run-qemu-robot-test.sh: OBMC_BUILD_DIR (掛載點，容器內路徑)
OBMC_BUILD_DIR=/tmp/openbmc/build

# ── Robot Framework ───────────────────────────────────────────────
# 對應 run-qemu-robot-test.sh: 測試腳本來源 (官方 git 專案)
ROBOT_SCRIPT_DIR=/home/andyeh/workspace/ci_test_area/openbmc-test-automation
# 對應 run-qemu-robot-test.sh: WORKSPACE (測試結果輸出目錄)
ROBOT_OUTPUT_DIR=/home/andyeh/workspace/openbmc-ai-bdd-portal/tests/bdd/reports
ROBOT_LOG_LEVEL=INFO

# ── Allure ────────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=/home/andyeh/workspace/openbmc-ai-bdd-portal/tests/bdd/reports/allure-results
