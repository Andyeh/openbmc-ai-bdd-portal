# ══════════════════════════════════════════════════════════════════
# OpenBMC AI-BDD Portal — Environment Variables (Example Template)
# Copy this file to '.env' and modify the values for your local system.
# ══════════════════════════════════════════════════════════════════

# ── Portal Server ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=true

# ── UPSTREAM_WORKSPACE ────────────────────────────────────────────
# Path to your OpenBMC build workspace
# Used as BASE_DIR in scripts (e.g., cd "${BASE_DIR}")
UPSTREAM_WORKSPACE=/home/username/workspace/openbmc/build/ast2700-default

# ── MACHINE ───────────────────────────────────────────────────────
# OpenBMC MACHINE name — decides the QEMU -machine flag
# Example values: ast2700-default (ast2700a1-evb), romulus (romulus-bmc)
MACHINE=ast2700-default

# ── QEMU Binary ───────────────────────────────────────────────────
# Absolute path to the QEMU system emulator binary
QEMU_BINARY=/home/username/workspace/openbmc/build/ast2700-default/tmp/work/x86_64-linux/qemu-helper-native/1.0/recipe-sysroot-native/usr/bin/qemu-system-aarch64

# ── QEMU Image Location ───────────────────────────────────────────
# Directory containing your BMC static MTD images (*.static.mtd)
QEMU_IMAGE_DIR=/home/username/workspace/openbmc/build/ast2700-default/tmp/deploy/images/ast2700-default
QEMU_DEFAULT_MACHINE=ast2700a1-evb

# ── QEMU Timer ───────────────────────────────────────────────────
# Maximum duration (in seconds) the QEMU docker container should live
QEMU_RUN_TIMER=3600
# Duration (in seconds) to wait for OpenBMC to boot and become ready
QEMU_LOGIN_TIMER=180
# Timeout (in seconds) for internal boot verification
QEMU_BOOT_TIMEOUT=300

# ── Docker ────────────────────────────────────────────────────────
# Docker image used to run the QEMU + Robot environment
DOCKER_IMG_NAME=openbmc/ast2700-robot-qemu:latest
DOCKER_SOCKET=/var/run/docker.sock
# Mount path for build artifacts inside the container
OBMC_BUILD_DIR=/tmp/openbmc/build

# ── Robot Framework ───────────────────────────────────────────────
# Path to the clone of official openbmc-test-automation repo
ROBOT_SCRIPT_DIR=/home/username/workspace/ci_test_area/openbmc-test-automation
# Directory where Robot Framework execution reports should be generated
ROBOT_OUTPUT_DIR=/home/username/workspace/openbmc-ai-bdd-portal/tests/bdd/reports
ROBOT_LOG_LEVEL=INFO

# ── Allure ────────────────────────────────────────────────────────
# Directory where Allure JSON results will be written for BDD tests
ALLURE_RESULTS_DIR=/home/username/workspace/openbmc-ai-bdd-portal/tests/bdd/reports/allure-results
