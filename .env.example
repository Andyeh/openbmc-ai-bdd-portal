# ──────────────────────────────────────────────
# OpenBMC AI-BDD Portal — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=true

# QEMU
# Binary: built by bitbake inside the romulus sysroot
QEMU_BINARY=/home/andyeh/workspace/openbmc/build/romulus/tmp/sysroots/x86_64-linux/usr/bin/qemu-system-arm
# Image directory: romulus deploy output (contains *.static.mtd)
QEMU_IMAGE_DIR=/home/andyeh/workspace/openbmc/build/romulus/tmp/deploy/images/romulus
QEMU_DEFAULT_MACHINE=romulus-bmc
QEMU_BOOT_TIMEOUT=300

# Robot Framework
# Official openbmc-test-automation git repository
ROBOT_SCRIPT_DIR=/home/andyeh/workspace/ci_test_area/openbmc-test-automation
ROBOT_OUTPUT_DIR=/home/andyeh/workspace/openbmc-ai-bdd-portal/tests/bdd/reports
ROBOT_LOG_LEVEL=INFO

# Docker / OpenBMC
DOCKER_IMAGE=openbmc-qemu:latest
DOCKER_SOCKET=/var/run/docker.sock

# Allure
ALLURE_RESULTS_DIR=/home/andyeh/workspace/openbmc-ai-bdd-portal/tests/bdd/reports/allure-results
